# Database
DATABASE_URL=postgresql+asyncpg://mirofish:mirofish@db:5432/mirofish
POSTGRES_USER=mirofish
POSTGRES_PASSWORD=mirofish
POSTGRES_DB=mirofish

# OpenAI (simulation agents)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (B2B reports)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Zep Cloud (agent memory)
ZEP_API_KEY=z_...

# App
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# Simulation defaults
DEFAULT_AGENT_COUNT=50
DEFAULT_TICK_DURATION_MS=2000
MAX_SIMULATION_TICKS=60
